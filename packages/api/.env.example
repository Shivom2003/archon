# PostgreSQL (Railway provides this automatically as DATABASE_URL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/archon

# Clerk — get from https://dashboard.clerk.com → API Keys
CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json
CLERK_API_KEY=sk_test_...          # for reading publicMetadata (beta_access check)

# Anthropic — used by archon library
ANTHROPIC_API_KEY=sk-ant-...
ARCHON_MODEL=claude-haiku-4-5            # interview phase (cost-efficient)
ARCHON_SYNTHESIS_MODEL=claude-sonnet-4-5 # synthesis phase (quality)

# CORS — set to your Vercel frontend URL
FRONTEND_URL=http://localhost:3000
