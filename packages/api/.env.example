# ── Database (Neon — https://neon.tech) ──────────────────────────────────────
# Get this from Neon dashboard → your project → Connection Details
# Select "Pooled connection" and choose "asyncpg" driver format, OR manually
# replace "postgresql://" with "postgresql+asyncpg://" in the Neon-provided URL.
# Do NOT append ?ssl=require — the app handles SSL automatically for neon.tech hosts.
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb

# ── Clerk (https://dashboard.clerk.com → API Keys) ───────────────────────────
# Frontend API value looks like: your-app.clerk.accounts.dev
# JWKS URL = https://<Frontend API value>/.well-known/jwks.json
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json

# Clerk Secret Key (used to verify beta_access in user metadata)
CLERK_API_KEY=sk_test_...

# ── Anthropic (https://console.anthropic.com → API Keys) ─────────────────────
# Used for the interview + synthesis passes.
# Phase 4 will replace this with per-user BYOK (Bring Your Own Key).
ANTHROPIC_API_KEY=sk-ant-...
ARCHON_MODEL=claude-haiku-4-5            # interview turns (cheap)
ARCHON_SYNTHESIS_MODEL=claude-sonnet-4-5 # synthesis pass (quality)

# ── CORS ─────────────────────────────────────────────────────────────────────
# Set to your Vercel frontend URL (no trailing slash).
# For local dev: http://localhost:3000
FRONTEND_URL=http://localhost:3000
