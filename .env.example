# Required: Anthropic API key for Claude (interview + architecture generation)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override the default model (default: claude-sonnet-4-5)
# ARCHON_MODEL=claude-opus-4-5
# ARCHON_FALLBACK_MODEL=claude-haiku-4-5

# Optional: Override output directory (default: .architect)
# ARCHON_OUTPUT_DIR=.architect

# Optional: Disable prompt caching (not recommended — increases cost)
# ARCHON_DISABLE_CACHE=false
